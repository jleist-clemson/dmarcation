{
    "name": "jonathanleist/dmarcation",
    "description": "A simple DMARC validator",
    "type": "project",
    "license": "Apache-2.0",
    "autoload": {
        "psr-4": {
            "Jonathanleist\\Dmarcation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jonathanleist\\Dmarcation\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "Jonathan Leist",
            "email": "jonathan@jonathanleist.com"
        }
    ],
    "bin": [
        "bin/dmarcation"
    ],
    "require": {
        "php": ">=8.2",
        "mikepultz/netdns2": "^2.0",
        "jeremykendall/php-domain-parser": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    }
}
